# Production should use a long random value. Example:
# openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-secret

# Comma-separated allowed browser origins for state-changing API requests.
# Same-host requests are allowed automatically; set this for reverse proxies or custom domains.
APP_ORIGIN=https://logingwak.xyz

# Cookie secure mode:
# - auto: Secure is used for HTTPS requests
# - true: always add Secure
# - false: never add Secure, useful only for plain HTTP testing
COOKIE_SECURE=auto

# Optional server settings
HOST=0.0.0.0
PORT=3000
DATA_DIR=./data
SQLITE_PATH=./data/htmlquizlab.sqlite
